# AI model access. PRODUCTION: use Vertex AI (ADC auth, no key) — mirrors the .NET backend.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=culinaai-backend
GOOGLE_CLOUD_LOCATION=europe-west3
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp_adc.json
FRA_GEMINI_MODEL=gemini-3.5-flash
# Local dev fallback ONLY (used when GOOGLE_GENAI_USE_VERTEXAI is false/unset).
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
FOOD_RESCUE_API_KEY=
DATABASE_URL=sqlite:///./fra1.db
MAX_IMAGE_SIZE_MB=10
MAX_IMAGES_PER_REQUEST=10
RATE_LIMIT_PER_MIN=60
HITL_BYPASS=false

# Reddit (PRIMARY channel) — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=CulinaAI FoodRescueBot/1.0
REDDIT_SUBREDDITS=noscrapleftbehind+mealprep+EatCheapAndHealthy
# Where the reddit-monitor reaches the FastAPI agent (compose service name)
FOOD_RESCUE_AGENT_URL=http://food-rescue-agent:8080
# SAFETY: auto-post approved replies to Reddit. Keep FALSE (dry-run) until the bot
# account + subreddit rules are cleared — otherwise risks anti-spam/rule bans.
# When false, HITL approve logs + shows the reply for manual copy (no comment created).
REDDIT_POST_ENABLED=false
